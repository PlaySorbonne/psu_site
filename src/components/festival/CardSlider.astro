---
import { Image } from "astro:assets";
import Card, { type CardInfo } from "./Card.astro";

type Props = {
  cards: CardInfo[];
  imgOnly?: boolean;
};

const { cards, imgOnly } = Astro.props;

const duration = `${Math.max(cards.length, 1) * 4}s`;

// les liens internes (pages du site) s'ouvrent dans le même onglet
const estExterne = (link?: string) => !!link && !link.startsWith("/");

// On rend deux copies identiques : la piste défile de 0 à -50%, donc à la fin
// la 2ᵉ copie est exactement là où était la 1ʳᵉ → boucle sans couture.
const copies = [0, 1];
---

<div class="marquee">
  <div class="track" style={{ "--duration": duration }}>
    {
      copies.map((copy) =>
        cards.map((card) => (
          <a
            class:list={["element", { clone: copy === 1 }]}
            href={card.link}
            target={estExterne(card.link) ? "_blank" : undefined}
            rel={estExterne(card.link) ? "noopener noreferrer" : undefined}
            aria-hidden={copy === 1 ? "true" : undefined}
            tabindex={copy === 1 ? -1 : undefined}
          >
            {!imgOnly ? (
              <Card {...card} />
            ) : typeof card.image === "string" ? (
              <Image
                src={card.image}
                alt={card.titre}
                height={200}
                loading="lazy"
                decoding="async"
                inferSize
              />
            ) : (
              <Image
                src={card.image}
                alt={card.titre}
                height={200}
                loading="lazy"
                decoding="async"
              />
            )}
          </a>
        )),
      )
    }
  </div>
</div>

<style>
  .marquee {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
  }

  .track {
    display: flex;
    width: max-content;
    padding: 20px 0;
    animation: scroll var(--duration) linear infinite;
  }

  /* Pause au survol. */
  .marquee:hover .track {
    animation-play-state: paused;
  }

  .element {
    flex: 0 0 auto;
    margin: 0 10px;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* Accessibilité */
  @media (prefers-reduced-motion: reduce) {
    .marquee {
      overflow-x: auto;
    }
    .track {
      animation: none;
      width: auto;
    }
    .clone {
      display: none;
    }
  }
</style>

---
import Footer from "@/components/global/Footer.astro";
import HeaderL from "@/layouts/partials/HeaderL.astro";
import ColorLigne from "@/components/global/ColorLigne.astro";
import { Image } from "astro:assets";
import { clubLogos } from "@/assets/logos/psu";
import logos from "@/assets/logos";
import { getDevs, devSlug } from "@/helpers/gamedevs";

const devs = await getDevs();
---

<HeaderL
  title="Les studios du Festival Play Sorbonne"
  description="Tous les développeurs et créateurs indépendants présents au Festival Play Sorbonne, et leurs jeux."
  metaImg="/assets/festival/logo_festival.png"
>
  <header class="header">
    <a href="/festival">
      <Image src={clubLogos.psu} alt="" class="logo__header" height="80" />
    </a>
  </header>
  <main>
    <section class="banner">
      <h1 class="title__banner redNeon">Les studios</h1>
      <p class="subtitle__banner">
        Développeurs et créateurs indépendants du Festival Play Sorbonne 2026
      </p>
    </section>
    <section class="section">
      <div class="content">
        <div class="title__list">
          <h2 class="title">Ils présentent leurs jeux au festival</h2>
          <ColorLigne />
        </div>
        {
          devs.length === 0 && (
            <p class="empty">
              Les studios de cette édition seront bientôt annoncés, revenez un
              peu plus tard !
            </p>
          )
        }
        <div class="grid">
          {
            devs.map((dev) => (
              <a class="studio" href={`/festival/devs/${devSlug(dev)}`}>
                <div class="logo__wrapper">
                  {dev.logo_studio ? (
                    <Image
                      class="logo"
                      src={dev.logo_studio}
                      alt={dev.nom_studio}
                      width={400}
                      loading="lazy"
                      decoding="async"
                      inferSize
                    />
                  ) : (
                    <Image
                      class="logo"
                      src={logos.psu.champsu}
                      alt=""
                      width={400}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="infos">
                  <h3 class="nom">{dev.nom_studio}</h3>
                  {dev.jeux.length > 0 && (
                    <p class="jeux">
                      {dev.jeux.map((jeu) => jeu.nom_jeu).join(" · ")}
                    </p>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</HeaderL>
<Footer />

<style>
  :root {
    --main-color: 232, 101, 173;
    --secondary-color: 41, 200, 255;
    --dark-color: 61, 61, 111;
    --main-bg: #f6f6f6;
  }

  main {
    width: 100%;
    overflow-x: hidden;
  }

  .header {
    z-index: 1000;
    position: fixed;
    top: 0;
    height: 100px;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    color: whitesmoke;
    border-bottom: rgba(255, 255, 255, 0.2) 1px solid;
    transition: top 0.3s;

    display: flex;
    align-items: center;
    justify-content: center;
  }

  .banner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    min-height: 320px;
    padding: 140px 2rem 2.5rem;
    background: linear-gradient(
      190deg,
      rgba(2, 0, 36, 1) 0%,
      rgb(41, 13, 97) 55%,
      #29105e 80%,
      rgb(75, 9, 44) 100%
    );
  }

  .title__banner {
    font-family: "No Continue", sans-serif;
    font-weight: lighter;
    text-transform: uppercase;
    color: white;
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: 2px;
    text-align: center;
  }

  .redNeon {
    text-shadow: 0 0 15px rgb(var(--main-color));
  }

  .subtitle__banner {
    color: rgb(177, 225, 241);
    font-weight: lighter;
    font-family: "No Continue", sans-serif;
    text-transform: uppercase;
    text-align: center;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    text-shadow: 0 0 7px rgb(var(--secondary-color));
  }

  .section {
    padding: 2rem;
  }

  .content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .title {
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .title__list {
    margin-bottom: 2rem;
  }

  .empty {
    text-align: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .studio {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 10px;
    background: white;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: all 0.5s ease-in-out;
  }

  .studio:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .logo__wrapper {
    height: 180px;
    background: rgb(var(--dark-color));
  }

  .logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .infos {
    padding: 1rem;
  }

  .nom {
    font-size: 1.3rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .jeux {
    color: rgba(var(--black-text), 0.8);
    text-align: left;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    let prevScrollPos = window.scrollY;

    window.addEventListener("scroll", function () {
      const currentScrollPos = window.scrollY;
      const header = document.querySelector<HTMLElement>(".header");
      if (!header) return;

      if (prevScrollPos > currentScrollPos || currentScrollPos < 80) {
        header.style.top = "0";
      } else {
        header.style.top = "-200px";
      }

      prevScrollPos = currentScrollPos;
    });
  });
</script>
